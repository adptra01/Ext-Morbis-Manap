{
  "manifest_version": 3,
  "name": "Open Detail in New Tab",
  "version": "1.1.0",
  "description": "Override tombol detail agar buka tab baru untuk semua website",
  "author": "Your Name",
  "icons": {
    "16": "icons/bluemorbis16.png",
    "48": "icons/bluemorbis48.png",
    "128": "icons/bluemorbis128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Detail in New Tab"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"]
}
